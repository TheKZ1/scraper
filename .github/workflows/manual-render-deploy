name: Manual Render Deploy

on:
  workflow_dispatch:
    inputs:
      note:
        description: Optional note for why this deploy was triggered
        required: false
        type: string

jobs:
  deploy:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    concurrency:
      group: manual-render-deploy
      cancel-in-progress: false

    steps:
      - name: Show trigger context
        run: |
          echo "Triggered by: ${{ github.actor }}"
          echo "UTC now: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
          echo "Amsterdam now: $(TZ=Europe/Amsterdam date '+%Y-%m-%d %H:%M:%S %Z')"
          echo "Note: ${{ inputs.note || 'none' }}"

      - name: Validate deploy hook secret
        run: |
          if [ -z "${{ secrets.RENDER_DEPLOY_HOOK_URL }}" ]; then
            echo "RENDER_DEPLOY_HOOK_URL secret is missing"
            exit 1
          fi

      - name: Trigger Render deploy hook
        run: |
          set -euo pipefail
          HTTP_CODE=$(curl -sS -o /tmp/render_response.txt -w "%{http_code}" -X POST "${{ secrets.RENDER_DEPLOY_HOOK_URL }}")
          echo "Render hook HTTP status: ${HTTP_CODE}"
          cat /tmp/render_response.txt || true
          if [ "$HTTP_CODE" -lt 200 ] || [ "$HTTP_CODE" -ge 300 ]; then
            echo "Render deploy hook failed"
            exit 1
          fi
          echo "Render deploy hook triggered"
